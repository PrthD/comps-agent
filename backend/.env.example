# --- Gemini (agent mode) ---
# Leave GEMINI_API_KEY empty to run in deterministic mode (no LLM, no key required).
GEMINI_API_KEY=

# --- CORS ---
# Comma-separated allowed origins (the frontend URL in production).
ALLOWED_ORIGINS=http://localhost:5173

# --- Optional model overrides (defaults live in app/config.py) ---
# GEMINI_REASONING_MODEL=gemini-2.5-flash
# GEMINI_EXTRACTION_MODEL=gemini-2.5-flash-lite
